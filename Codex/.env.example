# Kinopoisk API Unofficial
MOVIE_TRACKER_API__KEY=

# Alternative aliases supported by the app
KINOPOISK_API_KEY=
KINOPOISK_UNOFFICIAL_API_KEY=

# Optional: move local data/cache for tests or portable usage
MOVIE_TRACKER_HOME=

# Output overrides
MOVIE_TRACKER_OUTPUT__FORMAT=table
MOVIE_TRACKER_OUTPUT__LANGUAGE=ru-RU
MOVIE_TRACKER_OUTPUT__COLOR=true

# Logging
MOVIE_TRACKER_LOGGING__LEVEL=WARNING
